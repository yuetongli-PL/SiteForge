{
  "name": "siteforge",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run verify",
    "verify": "npm run release:local",
    "check:syntax": "node tools/check-syntax.mjs",
    "lint": "npm run lint:whitespace",
    "lint:whitespace": "git diff --check",
    "readme:generate": "node tools/generate-readme.mjs",
    "readme:check": "node tools/generate-readme.mjs --check",
    "clean:outputs": "node tools/clean-transient-outputs.mjs",
    "release:local": "npm run readme:check && npm run check:syntax && npm run test:node:focused && npm run test:node:all && npm run test:python && npm run scan:secrets && git diff --check",
    "scan:secrets": "node tools/prepublish-secret-scan.mjs",
    "test": "npm run test:ci",
    "test:ci": "npm run test:node:focused && npm run test:python",
    "test:node": "npm run test:node:focused",
    "test:node:all": "node --test --test-timeout=120000 tests/node/**/*.test.mjs",
    "test:node:focused": "node tools/run-package-scripts.mjs test:cli test:pipeline test:capability test:core",
    "test:cli": "node --test --test-concurrency=1 tests/node/cli-compat.test.mjs tests/node/cli-command-map-contract.test.mjs tests/node/pipeline-cli-values.test.mjs tests/node/progress-cli-integration.test.mjs tests/node/progress-renderer.test.mjs",
    "test:pipeline": "node --test --test-concurrency=1 tests/node/siteforge-build.test.mjs tests/node/siteforge-build-hardening.test.mjs tests/node/siteforge-build-x-output-regression.test.mjs tests/node/siteforge-output-validation.test.mjs tests/node/build-artifact-contract.test.mjs tests/node/siteforge-runtime-registry.test.mjs tests/node/siteforge-cross-site-regression.test.mjs tests/node/siteforge-x-generic-live-uncollectable.test.mjs",
    "test:capability": "node --test --test-concurrency=1 tests/node/siteforge-auto-capabilities.test.mjs tests/node/siteforge-confirmation-flow.test.mjs tests/node/siteforge-capability-interaction.test.mjs tests/node/site-capability-config-lint.test.mjs tests/node/site-capability-compiler-executor/compile-entrypoint.test.mjs tests/node/site-capability-compiler-executor/planner-integration.test.mjs tests/node/skill-coverage-regression-gate.test.mjs",
    "test:core": "node --test --test-concurrency=1 tests/node/architecture-import-rules.test.mjs tests/node/session-view.test.mjs tests/node/social-auth-import.test.mjs tests/node/cdp-client.test.mjs tests/node/test-coverage-regression.test.mjs tests/node/src-architecture-layout.test.mjs tests/node/known-site-paths.test.mjs tests/node/bilibili-action-router.test.mjs tests/node/site-doctor-download.test.mjs tests/node/site-capability-compiler-executor/config-loader.test.mjs tests/node/site-registry-availability.test.mjs tests/node/shared-concurrency.test.mjs tests/node/internal-options.test.mjs tests/node/status-vocabulary.test.mjs tests/node/xiaohongshu-fresh-evidence-redaction.test.mjs",
    "test:unit": "node --test tests/node/architecture-import-rules.test.mjs tests/node/skill-coverage-regression-gate.test.mjs",
    "test:integration": "node --test tests/node/progress-cli-integration.test.mjs tests/node/site-capability-compiler-executor/compile-entrypoint.test.mjs tests/node/site-capability-compiler-executor/planner-integration.test.mjs",
    "test:e2e": "node --test tests/node/siteforge-build.test.mjs",
    "test:python": "node tools/run-python-tests.mjs",
    "build": "npm run build:ci",
    "build:ci": "node --test tests/node/siteforge-build.test.mjs"
  },
  "bin": {
    "siteforge": "src/entrypoints/cli/index.mjs"
  }
}

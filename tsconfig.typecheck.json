{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "schema/**/*.mjs",
    "scripts/**/*.mjs",
    "src/**/*.mjs",
    "tests/node/**/*.mjs",
    "tools/**/*.mjs",
    "types/**/*.d.ts"
  ],
  "exclude": [
    ".siteforge",
    "book-content",
    "knowledge-base",
    "node_modules",
    "profiles",
    "runs",
    "skills"
  ]
}
